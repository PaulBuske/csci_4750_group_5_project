{
  "name": "csci_4750_group_5_project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "ts-node prisma/seed.ts",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "studio": "prisma studio",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:db:up": "docker compose -f docker-compose.test.yaml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yaml down",
    "test:db:reset": "dotenv -e .env.test -- npx prisma migrate deploy && dotenv -e .env.test -- npx ts-node prisma/seed.ts",
    "test:e2e": "dotenv -e .env.test -- npx playwright test",
    "test:e2e:ui": "dotenv -e .env.test -- npx playwright test --ui"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.0.2",
    "@mui/material": "^7.0.2",
    "@mui/x-data-grid": "^8.1.0",
    "@mui/x-date-pickers": "^8.0.0",
    "@neondatabase/serverless": "^1.0.0",
    "@prisma/client": "^6.6.0",
    "bcrypt": "^5.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "jose": "^6.0.10",
    "next": "15.3.0",
    "next-auth": "^4.24.11",
    "prisma": "^6.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.17.30",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.0"
  }
}
