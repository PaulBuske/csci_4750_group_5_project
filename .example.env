# Database connection strings
DATABASE_URL="postgres://username:password@your-postgres-host.example.com/your_database?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://username:password@your-postgres-host.example.com/your_database?sslmode=require"

# PostgreSQL connection details
PGDATABASE="your_database"
PGHOST="your-postgres-host.example.com"
PGHOST_UNPOOLED="your-postgres-unpooled-host.example.com"
PGPASSWORD="your_password"
PGUSER="your_username"

# Postgres configuration for Vercel
POSTGRES_DATABASE="your_database"
POSTGRES_HOST="your-postgres-host.example.com"
POSTGRES_PASSWORD="your_password"
POSTGRES_PRISMA_URL="postgres://username:password@your-postgres-host.example.com/your_database?pgbouncer=true&connect_timeout=15&sslmode=require"
POSTGRES_URL="postgres://username:password@your-postgres-host.example.com/your_database?sslmode=require"
POSTGRES_URL_NON_POOLING="postgres://username:password@your-postgres-host.example.com/your_database?sslmode=require"
POSTGRES_URL_NO_SSL="postgres://username:password@your-postgres-host.example.com/your_database"
POSTGRES_USER="your_username"

# JWT configuration
JWT_SECRET="your_secure_jwt_secret_key_at_least_32_chars"

# Vercel authentication
VERCEL_OIDC_TOKEN="your_vercel_oidc_token"

# Local development configuration
# Place at the end of .env file. Prisma will use the last DATABASE_URL it finds.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/timemanagement?schema=public"

# Testing configuration (see .env.test — committed to repo)
# Test DB runs on port 5433 via docker-compose.test.yaml
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/timemanagement_test?schema=public"

