datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  userId      String      @id @unique @default(uuid())
  email       String      @unique
  name        String?
  password    String
  hourlyRate  Decimal     @default(0.00) @db.Decimal(10, 2)
  role        UserRole    @default(EMPLOYEE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  sessions    Session[]
  timeEntries TimeEntry[]
  payPeriods  PayPeriod[]
}

enum UserRole {
  EMPLOYEE
  MANAGER
  ADMIN
}

model Session {
  sessionId String   @id @unique @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model TimeEntry {
  timeEntryId   String    @id @unique @default(uuid())
  userId        String
  clockInTime   DateTime
  clockOutTime  DateTime?
  minutesWorked Int? // Duration in minutes
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payPeriodId   String?

  user      User       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  payPeriod PayPeriod? @relation(fields: [payPeriodId], references: [payPeriodId])
}

model PayPeriod {
  payPeriodId String    @id @unique @default(uuid())
  userId      String
  startDate   DateTime
  endDate     DateTime
  totalHours  Decimal   @default(0.00) @db.Decimal(10, 2)
  grossPay    Decimal   @default(0.00) @db.Decimal(10, 2)
  status      PayStatus @default(PENDING)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User        @relation(fields: [userId], references: [userId], onDelete: Cascade)
  timeEntries TimeEntry[]
}

enum PayStatus {
  PENDING
  PROCESSED
  PAID
}
